{
  "name": "secretspec",
  "version": "0.15.0",
  "description": "Declarative secrets, every environment, any provider (Node.js SDK)",
  "license": "Apache-2.0",
  "homepage": "https://secretspec.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cachix/secretspec.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "secretspec.node"
  ],
  "napi": {
    "binaryName": "secretspec",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "bash scripts/build-addon.sh",
    "test": "node --test"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  },
  "optionalDependencies": {
    "secretspec-linux-x64-gnu": "0.12.2",
    "secretspec-linux-arm64-gnu": "0.12.2",
    "secretspec-darwin-arm64": "0.12.2",
    "secretspec-win32-x64-msvc": "0.12.2"
  }
}
